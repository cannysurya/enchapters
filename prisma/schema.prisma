generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  
  // NextAuth relations
  accounts      Account[]
  sessions      Session[]
  
  // App relations
  accesses      UserAccess[]
  progress      ReadingProgress[]
  annotations   Annotation[]
  bookmarks     Bookmark[]
  metrics       MetricEvent[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  USER
  MEMBER
  ADMIN
}

model Book {
  id            String    @id @default(cuid())
  title         String
  coverImage    String?
  content       String    // HTML string
  visibility    Visibility @default(FREE)
  
  accesses      UserAccess[]
  progress      ReadingProgress[]
  annotations   Annotation[]
  bookmarks     Bookmark[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Visibility {
  FREE
  EARLY_ACCESS
  HIDDEN
}

model UserAccess {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, bookId])
}

model ReadingProgress {
  id               String   @id @default(cuid())
  userId           String
  bookId           String
  lastReadPage     Int      @default(0)
  scrollPosition   Int      @default(0)
  timeSpentSeconds Int      @default(0)
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book             Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  
  updatedAt        DateTime @updatedAt
  
  @@unique([userId, bookId])
}

model Annotation {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  rangeData String   // Serialized range
  text      String   // Highlighted text
  note      String?  // Optional note
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bookmark {
  id             String   @id @default(cuid())
  userId         String
  bookId         String
  scrollPosition Int
  label          String?  // e.g. "Chapter 3" or user-defined label

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book           Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@unique([userId, bookId, scrollPosition])
}

model MetricEvent {
  id        String   @id @default(cuid())
  userId    String?  // nullable for anonymous events
  eventType String   // e.g., 'LOGIN', 'READ_START'
  metadata  String?  // JSON string
  timestamp DateTime @default(now())
  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// NextAuth standard models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
